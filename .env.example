# provider-proxy environment reference
# Copy to .env and uncomment only what your mode needs. Do not commit .env.
# This file is the single source of truth for supported environment variables.

# --- Core proxy ---
# PROXY_PORT=9999                    # Local listen port.
# PROXY_BIND=127.0.0.1               # Bind address. Use 0.0.0.0 only for trusted non-loopback clients and firewall it.
# DEBUG_PROXY=0                      # Set 1 to log redacted upstream URL, headers, and body summary.
# DEBUG_BODY=0                       # Set 1 with DEBUG_PROXY=1 to log full request bodies. May expose secrets.

# --- Single-target reverse proxy ---
# TARGET_HOST=app.manifest.build     # Upstream hostname for ordinary proxy routes.
# TARGET_PROTOCOL=https              # https or http.
# TARGET_PORT=443                    # Defaults to 443 for https, 80 for http.

# --- Multi-target reverse proxy ---
# TARGETS='[{"pathPrefix":"/kimi","host":"api.kimi.com","headers":{"x-app":"cli"}},{"pathPrefix":"/openai","host":"api.openai.com"}]'
# USER_AGENT='claude-cli/2.1.139 (external, cli)'  # Optional injected User-Agent.
# EXTRA_HEADERS='{"x-app":"cli"}'   # Optional JSON object injected into all upstream requests.

# --- Built-in /agy provider ---
# AGY_PATH_PREFIX=/agy               # Route prefix.
# AGY_BIN=agy                        # CLI binary or absolute path to agy/agy.exe.
# AGY_MODEL=agy/antigravity          # Primary model ID returned by /agy/v1/models.
# AGY_MODEL_SETTING=Gemini 3.5 Flash (Medium)  # Antigravity settings.json model value for AGY_MODEL.
# AGY_SECONDARY_MODEL=agy/antigravity-opus     # Secondary model ID returned by /agy/v1/models.
# AGY_SECONDARY_MODEL_SETTING=Claude Opus 4.6 (Thinking)  # Antigravity settings.json model value for AGY_SECONDARY_MODEL.
# AGY_SETTINGS_PATH=                 # Optional override for Antigravity CLI settings.json path.
# AGY_TIMEOUT_MS=300000              # Per-request timeout in milliseconds.
# AGY_MAX_CONCURRENCY=1              # Max concurrent agy subprocesses.
# AGY_PROVIDER_API_KEY=              # Optional local shared secret: bearer token required by /agy/v1 clients.
# AGY_USE_PTY=1                      # Default: enabled when node-pty is installed. Set 0 to force plain pipes.
# AGY_ARG_PROMPT_MAX_BYTES=16000     # Larger prompts are written to a temp file and passed by reference.
# AGY_DEFAULT_WORKSPACE=              # Absolute existing directory used when /agy requests omit X-Workspace-Dir/X-Claude-Workspace-Dir.
# AGY_DEBUG=0                        # Set 1 for subprocess diagnostics.
# AGY_PORT=9996                      # Standalone agy-provider.js only, not provider-proxy.js.

# --- Built-in /ollama provider ---
# OLLAMA_PATH_PREFIX=/ollama         # Route prefix.
# OLLAMA_BASE_URL=http://127.0.0.1:11434  # Manual Ollama upstream URL; also accepts https://...trycloudflare.com or https://...ngrok-free.app.
# OLLAMA_NGROK_SKIP_BROWSER_WARNING=0     # Set 1 only for ngrok-backed upstreams.
# OLLAMA_PROVIDER_API_KEY=           # Optional local shared secret: bearer token required by /ollama/v1 clients; stripped before upstream.
# OLLAMA_MODEL=ollama                # Informational model label returned by GET /ollama/.

# --- Kaggle self-healing Ollama keeper ---
# KAGGLE_OLLAMA_AUTO=0               # Set 1 to enable keeper auto-restart/discovery. If enabled, manually stopping Kaggle causes an automatic re-push.
# OLLAMA_KAGGLE_AUTO=0               # Backward-compatible alias.
# KAGGLE_KERNEL_SLUG=YOUR_KAGGLE_USERNAME/ollama-provider-via-ngrok  # Your Kaggle notebook slug.
# KAGGLE_OLLAMA_KERNEL_SLUG=         # Backward-compatible alias.
# KAGGLE_KERNEL_PATH=./kaggle-ollama-provider  # Local notebook folder used by kaggle kernels push.
# KAGGLE_OLLAMA_KERNEL_PATH=         # Backward-compatible alias.
# KAGGLE_ACCELERATOR=NvidiaTeslaT4   # Accelerator passed to kaggle kernels push --accelerator.
# KAGGLE_OLLAMA_ACCELERATOR=         # Backward-compatible alias.
# KAGGLE_STATUS_POLL_MS=30000        # Kernel status poll interval; keeper checks Kaggle about every 30s by default.
# KAGGLE_HEALTH_POLL_MS=60000        # Ollama /v1/models health-check interval.
# KAGGLE_PUSH_COOLDOWN_MS=300000     # Minimum delay between automatic pushes.
# KAGGLE_LOG_FOLLOW_MS=600000        # After pushing, follow live Kaggle logs this long to capture the tunnel URL.
# KAGGLE_IDLE_SHUTDOWN_MINUTES=30    # Minutes without successful /ollama/ traffic before stopping the Kaggle notebook and clearing upstream. Set 0 to disable idle shutdown.
# OLLAMA_URL_CALLBACK=                # Public HTTPS URL that forwards to local /ollama/callback, injected into the notebook by the TUI before push.
# OLLAMA_URL_CALLBACK_TOKEN=          # Optional bearer token required by /ollama/callback when the Kaggle notebook posts its tunnel URL.
# NGROK_AUTHTOKEN=                   # Optional local ngrok token for ngrok fallback/API discovery. Cloudflare quick tunnels do not need this.
